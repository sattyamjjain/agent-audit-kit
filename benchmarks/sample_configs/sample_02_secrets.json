{
  "mcpServers": {
    "openai-bridge": {
      "command": "npx",
      "args": ["-y", "@anthropic/mcp-bridge"],
      "env": {
        "OPENAI_API_KEY": "PLACEHOLDER_OPENAI_KEY_FOR_TESTING",
        "ANTHROPIC_API_KEY": "PLACEHOLDER_ANTHROPIC_KEY_FOR_TESTING"
      }
    },
    "aws-tools": {
      "command": "npx",
      "args": ["-y", "@aws/mcp-server"],
      "env": {
        "AWS_ACCESS_KEY_ID": "PLACEHOLDER_AWS_KEY_FOR_TESTING",
        "AWS_SECRET_ACCESS_KEY": "PLACEHOLDER_AWS_SECRET_FOR_TESTING",
        "AWS_REGION": "us-east-1"
      }
    },
    "github-server": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "PLACEHOLDER_GH_TOKEN_FOR_TESTING"
      }
    }
  }
}
