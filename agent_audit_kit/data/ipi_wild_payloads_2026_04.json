  "payloads": [
    {
      "id": "IPI-2026-04-WILD-01",
      "label": "ignore-prior + exfil",
      "regex": "(?i)ignore\\s+(?:all|previous|prior)\\s+(?:instructions|tools).*?(?:read|cat|leak|exfil|send)",
      "severity": "critical",
      "first_seen": "2026-04-24",
      "source_url": "https://www.helpnetsecurity.com/2026/04/24/indirect-prompt-injection-in-the-wild/"
    },
    {
      "id": "IPI-2026-04-WILD-02",
      "label": "system-role override",
      "regex": "(?i)<\\|?(?:system|admin|root)\\|?>.*?(?:execute|run|fetch|disclose)",
      "severity": "high",
      "first_seen": "2026-04-24",
      "source_url": "https://www.helpnetsecurity.com/2026/04/24/indirect-prompt-injection-in-the-wild/"
    },
    {
      "id": "IPI-2026-04-WILD-03",
