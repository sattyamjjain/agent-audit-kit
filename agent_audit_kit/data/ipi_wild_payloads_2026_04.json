      "regex": "(?i)(?:reveal|print|disclose|leak)\\s+(?:your|the)\\s+system\\s+prompt",
      "severity": "high",
      "first_seen": "2026-04-24",
      "source_url": "https://www.helpnetsecurity.com/2026/04/24/indirect-prompt-injection-in-the-wild/"
    },
    {
      "id": "IPI-2026-04-WILD-04",
      "label": "credential exfil via cURL",
      "regex": "(?i)curl\\s+[^\\n]*(?:GITHUB_TOKEN|GH_TOKEN|ANTHROPIC_API_KEY|OPENAI_API_KEY|AWS_SECRET)",
      "severity": "critical",
      "first_seen": "2026-04-24",
      "source_url": "https://www.helpnetsecurity.com/2026/04/24/indirect-prompt-injection-in-the-wild/"
    },
    {
      "id": "IPI-2026-04-WILD-05",
      "label": "tool-call rerouting",
      "regex": "(?i)redirect\\s+(?:tool|api)\\s+calls?\\s+to",
      "severity": "high",
      "first_seen": "2026-04-24",
      "source_url": "https://www.helpnetsecurity.com/2026/04/24/indirect-prompt-injection-in-the-wild/"
    },
    {
      "id": "IPI-2026-04-WILD-06",
